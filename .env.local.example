# Firebase — 계정(Auth) · 커뮤니티 게시글(Firestore) · 사진(Storage)에 필요
# Firebase 콘솔 → 프로젝트 설정 → 내 앱 → SDK 설정 및 구성 에서 값을 복사하세요.
# 이 파일을 .env.local 로 복사한 뒤 값을 채우고 개발 서버를 재시작하면 적용됩니다.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# 네이버 지도 (탐험 페이지)
# 클라이언트 ID는 공개 식별자이며, 실제 보호는 네이버 콘솔의 서비스 URL 등록이 담당합니다.
# 로컬에서 지도를 보려면 콘솔에 http://localhost:3000 이 등록돼 있어야 합니다.
# 자세한 내용: NAVER_MAPS_TROUBLESHOOTING.md
NEXT_PUBLIC_NAVER_MAP_CLIENT_ID=o8bhr6higo
