rules_version = '2';

// 봉황 메모리즈 — Firestore 보안 규칙
//
// 원칙
//  · 읽기는 공개 (커뮤니티·랭킹은 비로그인도 볼 수 있어야 한다)
//  · 쓰기는 로그인 사용자만
//  · 수정·삭제는 작성자 본인만 — 클라이언트 검사는 우회 가능하므로 여기서 강제한다
//  · 좋아요·댓글수는 남의 글에도 써야 하므로, 바뀔 수 있는 필드를 정확히 한정한다

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // 관리자 — 구글 로그인 토큰의 이메일로 판정한다.
    // admins 컬렉션을 두면 최초 관리자를 넣는 부트스트랩이 필요한데,
    // 토큰에 이메일이 있어 여기서 바로 비교할 수 있다.
    function isAdmin() {
      return request.auth != null
             && request.auth.token.email == 'socialceos@gmail.com';
    }

    // 이번 수정으로 실제 바뀐 필드 집합
    function changedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    // ───────── 사용자 프로필 ─────────
    // 닉네임을 게시글·랭킹에 표시해야 하므로 읽기는 공개.
    // 문서 ID가 곧 uid이므로 본인만 만들고 고칠 수 있다.
    match /users/{userId} {
      allow read: if true;
      allow create: if (isOwner(userId) && request.resource.data.uid == userId)
                    || isAdmin();
      allow update: if (isOwner(userId)
                        && request.resource.data.uid == resource.data.uid)
                    || isAdmin();
      // 관리자만 지울 수 있다 — 데모 데이터 정리용
      allow delete: if isAdmin();

      // ───────── 투어 진행도 ─────────
      // 닉네임·점수와 달리 남에게 보일 이유가 없다 — 본인만 읽고 쓴다.
      // 기기를 바꿔 로그인하면 여기서 이어 걷는다.
      match /progress/{docId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      // ───────── 포인트 적립 내역 ─────────
      // 문서 ID가 refId라 같은 미션을 두 번 완료해도 덮어쓰기가 되어
      // 중복 적립이 되지 않는다. 수정·삭제는 막는다.
      match /points/{refId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if (isOwner(userId)
                          && request.resource.data.points is int
                          && request.resource.data.points > 0
                          && request.resource.data.points <= 500)
                      || isAdmin();
        allow update: if isAdmin();
        allow delete: if isAdmin();
      }

      // ───────── 설문 응답 ─────────
      // 문서 ID가 surveyId라 한 설문에 한 번만 답할 수 있다.
      match /surveyResponses/{surveyId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) || isAdmin();
        allow update, delete: if isAdmin();
      }
    }

    // ───────── 설문 정의 ─────────
    // 문항을 코드가 아니라 여기 두어 배포 없이 바꾼다. 쓰기는 관리자만.
    match /surveys/{surveyId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ───────── 게시글 ─────────
    match /posts/{postId} {

      // 작성자 본인의 본문 수정 — 본문과 수정 표시만 건드릴 수 있다
      function isAuthorEdit() {
        return isOwner(resource.data.authorUid)
               && changedKeys().hasOnly(['comment', 'edited']);
      }

      // 좋아요 토글 — 자기 uid만 넣거나 뺄 수 있고, 카운트도 그에 맞아야 한다
      function isLikeToggle() {
        let before = resource.data.likedBy;
        let after = request.resource.data.likedBy;
        let me = [request.auth.uid].toSet();

        return isSignedIn()
               && changedKeys().hasOnly(['likes', 'likedBy'])
               && (
                 // 좋아요 누르기
                 (!(request.auth.uid in before)
                  && after.toSet() == before.toSet().union(me)
                  && request.resource.data.likes == resource.data.likes + 1)
                 ||
                 // 좋아요 취소
                 ((request.auth.uid in before)
                  && after.toSet() == before.toSet().difference(me)
                  && request.resource.data.likes == resource.data.likes - 1)
               );
      }

      // 댓글 작성·삭제에 따른 카운트 보정 — 1씩만 움직일 수 있다
      function isCommentCountChange() {
        return isSignedIn()
               && changedKeys().hasOnly(['commentCount'])
               && (request.resource.data.commentCount == resource.data.commentCount + 1
                   || request.resource.data.commentCount == resource.data.commentCount - 1);
      }

      allow read: if true;

      // 남의 이름으로 글을 쓰거나, 좋아요를 부풀린 채 시작할 수 없다
      allow create: if (isSignedIn()
                        && request.resource.data.authorUid == request.auth.uid
                        && request.resource.data.likes == 0
                        && request.resource.data.likedBy.size() == 0
                        && request.resource.data.commentCount == 0)
                    || isAdmin();

      allow update: if isAuthorEdit() || isLikeToggle() || isCommentCountChange();

      // 신고 대응 — 관리자도 지울 수 있다
      allow delete: if isOwner(resource.data.authorUid) || isAdmin();

      // ───────── 댓글 ─────────
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn()
                      && request.resource.data.authorUid == request.auth.uid;
        allow update: if false;
        allow delete: if isOwner(resource.data.authorUid);
      }
    }

    // ───────── 골목 가게 쿠폰 사용 기록 ─────────
    //
    // 문서 id가 쿠폰 코드다. 있으면 이미 쓴 것, 없으면 아직 안 쓴 것.
    // 이 컬렉션이 '한 번만 사용'을 실제로 보장하는 곳이다 — 코드 안의
    // 체크값은 오타를 잡을 뿐 위조를 막지 못한다(클라이언트에서 만든다).
    //
    // 가게 사장님에게 계정을 만들게 하면 현장에서 쓰이지 않으므로
    // 로그인을 요구하지 않는다. 대신 할 수 있는 일을 좁힌다:
    //  · 만들기만 되고 고치거나 지우지 못한다 → 쓴 것을 되돌릴 수 없다
    //  · 지우는 것은 관리자만 → 잘못 찍었을 때 되돌릴 길은 남긴다
    match /couponUses/{code} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasOnly(
                         ['couponId', 'shop', 'userTag', 'usedAt'])
                    && request.resource.data.usedAt == request.time;
      allow update: if false;
      allow delete: if isAdmin();
    }
  }
}
