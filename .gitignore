# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# 값이 비어 있는 템플릿은 추적한다 — 새로 받은 사람이 필요한 변수를 알 수 있도록
!.env*.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel
