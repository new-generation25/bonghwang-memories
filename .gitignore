# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# 값이 비어 있는 템플릿은 추적한다 — 새로 받은 사람이 필요한 변수를 알 수 있도록
!.env*.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel

# 음성 생성 — 줄 단위 캐시와 보이스 설정(개인 키 성격)
.audio-cache/
scripts/voices.json

# 일회성 TTS 실험 — 앱과 무관한 개인 작업물이라 저장소에 올리지 않는다.
# 도구(tts-once.mjs)는 API 키를 다루고, 산출물은 프로젝트 에셋이 아니다.
scripts/tts-once.mjs
tts-out/
*.sample.mp3
